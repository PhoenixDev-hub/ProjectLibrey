generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                   Int          @id @default(autoincrement())
  nome                 String
  sobrenome            String
  email                String       @unique
  senha                String
  anoSala              String?      @map("ano_sala")
  tipoUsuario          String       @map("tipo_usuario")
  anoInicioEnsinoMedio Int          @map("ano_inicio_ensino_medio")
  telefone             String?
  status               String       @default("ATIVO")
  dataCadastro         DateTime     @default(now()) @map("data_cadastro")
  refreshTokens        RefreshToken[]
  passwordResets       PasswordReset[]
  reservas          Reserva[]
  reservasAprovadas Reserva[] @relation("ReservasAprovadas")
  notificacoes      Notificacao[]

  @@map("usuarios")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  usuarioId Int       @map("usuario_id")
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  usuarioId Int       @map("usuario_id")
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("password_resets")
}

model Livro {
  id            String   @id @default(uuid())
  titulo        String
  autor         String
  editora       String?
  anoPublicacao Int?     @map("ano_publicacao")
  isbn          String?
  area          String
  sinopse       String?

  exemplares    Exemplar[]

  createdAt     DateTime @default(now()) @map("created_at")

  @@map("livros")
}

model Exemplar {
  id        String   @id @default(uuid())
  livroId   String   @map("livro_id")
  livro     Livro    @relation(fields: [livroId], references: [id])

  codigo    String   @unique
  status    String   @default("DISPONIVEL")

  reservas  Reserva[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("exemplares")
}

model Reserva {
  id           String   @id @default(uuid())

  usuarioId    Int      @map("usuario_id")
  exemplarId   String   @map("exemplar_id")

  status       String   @default("PENDENTE")

  aprovadoPor  Int?     @map("aprovado_por")
  aprovadoEm   DateTime? @map("aprovado_em")

  retiradoEm   DateTime? @map("retirado_em")
  prazoDevol   DateTime? @map("prazo_devolucao")
  devolvidoEm  DateTime? @map("devolvido_em")

  createdAt    DateTime @default(now()) @map("created_at")

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  aprovador Usuario? @relation("ReservasAprovadas", fields: [aprovadoPor], references: [id])
  exemplar  Exemplar @relation(fields: [exemplarId], references: [id])
  notificacoes Notificacao[]

  @@map("reservas")
}

model Notificacao {
  id    String    @id @default(uuid())
  usuarioId Int     @map("usuario_id")
  reservaId String? @map("reserva_id")
  tipo      String
  titulo    String
  mensagem  String
  lida    Boolean   @default(false)
  createdAt   DateTime    @default(now()) @map("created_at")

  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  reserva   Reserva? @relation(fields: [reservaId], references: [id])

  @@map("notificacoes")
}

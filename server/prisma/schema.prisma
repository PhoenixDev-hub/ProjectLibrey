generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum TipoUsuario {
  ALUNO
  PROFESSOR
  BIBLIOTECARIA
  ADMINISTRADOR
}

enum Status {
  ATIVO
  INATIVO
}

model Usuario {
  id                   Int          @id @default(autoincrement())
  nome                 String
  sobrenome            String
  email                String       @unique
  senha                String
  anoSala              String?
  tipoUsuario          TipoUsuario
  anoInicioEnsinoMedio Int
  telefone             String?
  status               Status       @default(ATIVO)
  dataCadastro         DateTime     @default(now())
  refreshTokens        RefreshToken[]
  passwordResets       PasswordReset[]

  @@map("usuarios")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  usuarioId Int
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@map("refresh_tokens")
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  usuarioId Int
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_resets")
}

model Livro {
  id            String   @id @default(uuid())
  titulo        String
  autor         String
  editora       String?
  anoPublicacao Int?
  isbn          String?
  area          AreaConhecimento
  sinopse       String?

  exemplares    Exemplar[]

  createdAt     DateTime @default(now())

  @@map("livros")
}

model Exemplar {
  id        String   @id @default(uuid())
  livroId   String
  livro     Livro    @relation(fields: [livroId], references: [id])

  codigo    String   @unique
  status    StatusExemplar @default(DISPONIVEL)

  reservas  Reserva[]

  createdAt DateTime @default(now())

  @@map("exemplares")
}

model Reserva {
  id           String   @id @default(uuid())

  usuarioId    Int
  exemplarId   String

  status       StatusReserva @default(PENDENTE)

  aprovadoPor  Int?
  aprovadoEm   DateTime?

  retiradoEm   DateTime?
  devolvidoEm  DateTime?

  createdAt    DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  exemplar  Exemplar @relation(fields: [exemplarId], references: [id])

  @@map("reservas")
}

enum AreaConhecimento {
  LINGUAGENS
  MATEMATICA
  CIENCIAS_NATUREZA
  CIENCIAS_HUMANAS
  LITERATURA
  TECNOLOGIA
  OUTRA
}

enum StatusExemplar {
  DISPONIVEL
  RESERVADO
  EMPRESTADO
  MANUTENCAO
}

enum StatusReserva {
  PENDENTE
  APROVADO
  REJEITADO
  RETIRADO
  DEVOLVIDO
  CANCELADO
  EXPIRADO
}
